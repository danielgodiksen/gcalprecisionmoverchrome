{
  "manifest_version": 3,
  "name": "GCal Precision Mover",
  "version": "1.6.2",
  "description": "Bulk-move Google Calendar events and reposition them in 1-minute increments (Alt+drag, Alt+arrow nudge, bulk shift panel).",
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": [
    "identity",
    "storage",
    "notifications",
    "alarms",
    "offscreen",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://www.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GCal Precision Mover — check for updates",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}